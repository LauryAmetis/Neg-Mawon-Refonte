        { "name": "Vert", "slug": "vert", "color": "#039446" },
        { "name": "Jaune", "slug": "jaune", "color": "#FDEF00" },
        { "name": "Corail", "slug": "corail", "color": "#F3611D" },
        { "name": "Rouge", "slug": "rouge", "color": "#EE2223" }        
      ]
